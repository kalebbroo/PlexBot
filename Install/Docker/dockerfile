# ── Build Stage ──────────────────────────────────────────────────────────────
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build

WORKDIR /source

COPY . .

RUN dotnet restore
RUN dotnet publish -c Release -o /app

# ── Runtime Stage (SDK required for live-source rebuild support) ─────────────
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS runtime

WORKDIR /app

# Install dependencies and fonts for CJK / emoji rendering (ImageSharp)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    fontconfig \
    fonts-dejavu \
    fonts-liberation \
    fonts-noto \
    fonts-noto-cjk \
    fonts-noto-color-emoji \
    fonts-ipafont-gothic \
    fonts-ipafont-mincho \
    && rm -rf /var/lib/apt/lists/*

# Copy build output (includes Images/ since it's part of the project)
COPY --from=build /app .

# Copy and set up the startup script (sed strips Windows \r line endings)
COPY Install/Docker/startup.sh /app/startup.sh
RUN sed -i 's/\r$//' /app/startup.sh && chmod +x /app/startup.sh

ENTRYPOINT ["/bin/bash", "/app/startup.sh"]
